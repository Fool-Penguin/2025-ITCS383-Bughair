{
  "name": "fitcourt-reservation-service",
  "version": "1.0.0",
  "description": "Court Reservation & Attendance Tracking — ITCS383",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "nyc node src/tests/courts.test.js"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nyc": "^15.1.0"
  },
  "nyc": {
    "reporter": [
      "lcov",
      "text"
    ],
    "all": true,
    "include": [
      "src/**/*.js"
    ],
    "exclude": [
      "src/tests/**"
    ],
    "extension": [
      ".js"
    ],
    "report-dir": "coverage"
  }
}
